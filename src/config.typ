// Default configuration constants for NTU thesis formatting.
// Based on 國立臺灣大學碩博士學位論文格式規範 (112.10.20)

// Page layout
#let page-width = 210mm
#let page-height = 297mm
#let margin-top = 3cm
#let margin-bottom = 2cm
#let margin-left = 3cm
#let margin-right = 3cm

// Typography
#let body-size = 12pt
#let heading-size = 18pt
#let subheading-size = 14pt

// English text
#let font-en = ("Times New Roman", "Libertinus Serif")

// Chinese text
#let font-zh = ("BiauKaiTC", "DFKai-SB", "Kaiti TC", "Kaiti SC")

// Spacing
#let line-spacing = 1.5em
